{
    "compilerOptions": {
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES2021",
        "moduleResolution": "bundler",
        "importHelpers": true,
        "isolatedModules": true,
        "strictNullChecks": true,
        "removeComments": true,
        "skipLibCheck": true,
        "lib": ["ES2021", "DOM"],
        "jsx": "react",
        "esModuleInterop": true,
        "paths": {
            "@/*": ["./src/*"],
            "@test/*": ["./tests/*"],
        },
        "types": ["jest", "node"]
    },
    "include": ["**/*.ts", "**/*.tsx", "**/*.mts"]
}
